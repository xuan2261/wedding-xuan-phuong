    },
    {
      "id": "R2-STORY-LAZY-PLACEHOLDER",
      "finding": "Auto-story could arrive at a lazy section before its images were fetched/decoded.",
      "fix": "Promote and decode up to four images for the current/next chapter with a bounded wait."
    },
    {
      "id": "R3-AUDIO-TIME-ORIGIN",
      "finding": "The prior clamp prevented invalid volume, but the fade still mixed performance.now() with rAF callback timestamps.",
      "fix": "Use the first rAF callback timestamp as the only fade origin."
    },
    {
      "id": "R4-HIDDEN-TAB-AUDIO",
      "finding": "Music could continue after the page became hidden.",
      "fix": "Pause on visibilitychange/pagehide and require explicit user action to resume."
    },
    {
      "id": "R5-STORY-DATA-COLLISION",
      "finding": "Body debug data-story-chapter collided with the Story Player live-region selector.",
      "fix": "Rename debug state to data-story-chapter-index and keep aria-live on the actual chapter label."
    },
    {
      "id": "R6-DEPLOY-NOT-PROVEN",
      "finding": "The workflow deployed Pages but did not prove the new build was live.",
      "fix": "Poll root marker, release.json and all four event entry pages after deploy."
    },
    {
      "id": "R7-GUEST-LINK-TOOL",
      "finding": "The offline guest-link generator still produced root hash links.",
